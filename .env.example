# Campaign Canvas - Environment Configuration Template
# Copy this file to .env and fill in your actual values

# Application Environment
ENVIRONMENT=development
# ENVIRONMENT=production  # Use for production deployments

# Clerk Authentication Configuration
# Get these values from your Clerk dashboard: https://dashboard.clerk.com
CLERK_CLIENT_ID=your_clerk_client_id_here
CLERK_CLIENT_SECRET=your_clerk_client_secret_here
CLERK_DOMAIN=your_domain.clerk.accounts.com
CLERK_REDIRECT_URI=http://localhost:8501/

# Database Configuration
# For production, you may want to use cloud-hosted SQLite or PostgreSQL
# DB_PATH is set programmatically in config.py but can be overridden here if needed
# DATABASE_URL=sqlite:///data/processed/marketing.db

# Feature Flags
ENABLE_MOCK_DATA_GENERATION=True
ENABLE_CACHING=True
ENABLE_DETAILED_LOGGING=False

# UI/UX Configuration
DEFAULT_THEME=dark
# DEFAULT_THEME=light  # Use for light mode

# Security Configuration
SESSION_TIMEOUT=3600  # 1 hour in seconds

# Logging Configuration
LOG_LEVEL=INFO
# LOG_LEVEL=DEBUG  # For development
# LOG_LEVEL=WARNING  # For production

# Performance Configuration
CACHE_TTL=300  # 5 minutes in seconds
MAX_ROWS_PER_QUERY=100000
QUERY_TIMEOUT=60

# Email Configuration (optional, for future notifications)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=your_email@gmail.com
# SMTP_PASSWORD=your_app_password
# SMTP_FROM_EMAIL=noreply@campaigncanvas.com

# Analytics (optional, for future analytics integration)
# POSTHOG_API_KEY=your_posthog_key
# POSTHOG_ENDPOINT=https://api.posthog.com
